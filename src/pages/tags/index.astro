---
import { getCollection } from 'astro:content';
import { Icon } from 'astro-icon/components';
import SiteLayout from '../../layouts/SiteLayout.astro';
import { getTagSummaries } from '../../utils/tags';

const posts = await getCollection('blog');
const tags = getTagSummaries(posts);
---

<SiteLayout pageTitle="Tags" centerTitle={true}>
	<section class="tags-shell">
		{
			tags.length === 0 ? (
				<p class="empty-state">No tags have been added to posts yet.</p>
			) : (
				<ul class="tag-grid">
					{tags.map((tag) => (
						<li>
							<a href={`/tags/${tag.slug}/`} class="tag-card">
								<span class="tag-card-icon">
									<Icon name="lucide:hash" width={18} height={18} />
								</span>
								<span class="tag-card-name">{tag.name}</span>
								<span class="tag-card-count">
									<Icon name="lucide:file-text" width={12} height={12} />
									{tag.count}
								</span>
							</a>
						</li>
					))}
				</ul>
			)
		}
	</section>
</SiteLayout>

<style>
	.tags-shell {
		width: min(860px, calc(100% - 2rem));
		margin: 2rem auto 4rem;
	}

	.empty-state {
		margin: 0;
		color: rgb(var(--gray));
	}

	.tag-grid {
		list-style: none;
		margin: 0;
		padding: 0;
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
		gap: 1rem;
	}

	.tag-card {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		padding: 1.1rem 1.2rem 1rem;
		background: rgb(var(--surface));
		border: 1px solid rgb(var(--gray-light));
		border-radius: 12px;
		text-decoration: none;
		color: rgb(var(--gray-dark));
		transition: border-color 0.15s, box-shadow 0.15s, color 0.15s;
	}

	.tag-card:hover {
		border-color: var(--accent);
		color: var(--accent);
		box-shadow: 0 4px 16px rgba(var(--gray), 20%);
	}

	.tag-card-icon {
		display: flex;
		align-items: center;
		color: var(--accent);
		opacity: 0.8;
	}

	.tag-card-name {
		font-size: 1rem;
		font-weight: 600;
		line-height: 1.2;
		word-break: break-word;
	}

	.tag-card-count {
		display: flex;
		align-items: center;
		gap: 0.3rem;
		margin-top: auto;
		font-size: 0.8rem;
		color: rgb(var(--gray));
	}

	.tag-card:hover .tag-card-count {
		color: var(--accent);
		opacity: 0.75;
	}
</style>
