---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { Icon } from 'astro-icon/components';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`About — ${SITE_TITLE}`} description="Get to know the person behind this blog." />
  </head>
  <body>
    <Header />
    <main>

      <!-- ── Hero ─────────────────────────────────────────── -->
      <section class="about-hero">
        <div class="avatar">FM</div>
        <div class="hero-text">
          <h1 class="hero-name">FenMin</h1>
          <p class="hero-role">Software Engineer &amp; Writer</p>
          <p class="hero-tagline">
            I build things for the web, think too much about system design,<br />
            and occasionally write about what I learn.
          </p>
          <div class="hero-links">
            <a href="https://github.com/" target="_blank" rel="noopener" class="hero-link">
              <Icon name="lucide:github" width={16} height={16} />
              GitHub
            </a>
            <a href="/blog" class="hero-link">
              <Icon name="lucide:book-open" width={16} height={16} />
              Blog
            </a>
            <a href="mailto:you@example.com" class="hero-link">
              <Icon name="lucide:mail" width={16} height={16} />
              Email
            </a>
          </div>
        </div>
      </section>

      <div class="about-body">

        <!-- ── About Me ──────────────────────────────────── -->
        <section class="about-section">
          <h2 class="section-heading">
            <Icon name="lucide:user" width={16} height={16} />
            About Me
          </h2>
          <div class="prose">
            <p>
              Hi — I'm FenMin. I'm a software engineer with a passion for backend systems,
              distributed architecture, and clean code. I started this blog as a way to
              document what I learn and share ideas that I think are worth reading.
            </p>
            <p>
              When I'm not coding, I'm usually reading, hiking, or brewing coffee badly.
              I believe the best software is simple, predictable, and boring in the best
              possible way.
            </p>
          </div>
        </section>

        <!-- ── Tech Stack ─────────────────────────────────── -->
        <section class="about-section">
          <h2 class="section-heading">
            <Icon name="lucide:cpu" width={16} height={16} />
            Tech I Work With
          </h2>
          <div class="stack-grid">
            {[
              { label: 'Java', icon: 'lucide:coffee' },
              { label: 'Spring Boot', icon: 'lucide:layers' },
              { label: 'Go', icon: 'lucide:terminal' },
              { label: 'Python', icon: 'lucide:code-2' },
              { label: 'Kubernetes', icon: 'lucide:boxes' },
              { label: 'PostgreSQL', icon: 'lucide:database' },
              { label: 'Redis', icon: 'lucide:zap' },
              { label: 'Docker', icon: 'lucide:container' },
              { label: 'TypeScript', icon: 'lucide:file-code-2' },
              { label: 'System Design', icon: 'lucide:network' },
            ].map(({ label, icon }) => (
              <span class="stack-chip">
                <Icon name={icon} width={13} height={13} />
                {label}
              </span>
            ))}
          </div>
        </section>

        <!-- ── Currently ──────────────────────────────────── -->
        <section class="about-section">
          <h2 class="section-heading">
            <Icon name="lucide:sparkles" width={16} height={16} />
            Currently
          </h2>
          <ul class="currently-list">
            <li>
              <span class="dot dot--green"></span>
              Working on microservices architecture and distributed transactions
            </li>
            <li>
              <span class="dot dot--blue"></span>
              Writing about Java, Spring Boot, and system design patterns
            </li>
            <li>
              <span class="dot dot--purple"></span>
              Learning more about Kubernetes internals and cloud-native patterns
            </li>
            <li>
              <span class="dot dot--orange"></span>
              Reading: <em>Designing Data-Intensive Applications</em>
            </li>
          </ul>
        </section>

        <!-- ── Quote ──────────────────────────────────────── -->
        <blockquote class="about-quote">
          "The art of programming is the art of organizing complexity."
          <cite>— Edsger W. Dijkstra</cite>
        </blockquote>

      </div>
    </main>
    <Footer />
  </body>
</html>

<style>
  main {
    flex: 1;
    width: 100%;
    max-width: 100%;
    margin: 0;
    padding: 0;
  }

  /* ── Hero ────────────────────────────────────────────── */
  .about-hero {
    display: flex;
    align-items: center;
    gap: 2.5rem;
    max-width: 780px;
    margin: 3.5rem auto 0;
    padding: 0 1.5rem 3rem;
    border-bottom: 1px solid rgb(var(--gray-light));
  }

  .avatar {
    flex-shrink: 0;
    width: 96px;
    height: 96px;
    border-radius: 50%;
    background: var(--accent);
    color: #fff;
    font-size: 1.6rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 24px rgba(var(--gray), 28%);
    user-select: none;
  }

  .hero-name {
    margin: 0 0 0.2rem;
    font-size: 2rem;
    font-weight: 700;
    color: rgb(var(--black));
    line-height: 1.1;
  }

  .hero-role {
    margin: 0 0 0.65rem;
    font-size: 0.9rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.09em;
    color: var(--accent);
  }

  .hero-tagline {
    margin: 0 0 1.25rem;
    font-size: 0.975rem;
    line-height: 1.65;
    color: rgb(var(--gray-dark));
  }

  .hero-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }

  .hero-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.38rem 0.9rem;
    border: 1px solid rgb(var(--gray-light));
    border-radius: 99px;
    font-size: 0.82rem;
    font-weight: 500;
    text-decoration: none;
    color: rgb(var(--gray-dark));
    background: rgb(var(--surface));
    transition: border-color 140ms, color 140ms;
  }
  .hero-link:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  /* ── Body sections ───────────────────────────────────── */
  .about-body {
    max-width: 780px;
    margin: 0 auto;
    padding: 0 1.5rem 5rem;
  }

  .about-section {
    margin-top: 3rem;
  }

  .section-heading {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    margin: 0 0 1.1rem;
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgb(var(--gray));
  }

  /* ── Prose ───────────────────────────────────────────── */
  .prose p {
    margin: 0 0 1rem;
    font-size: 1rem;
    line-height: 1.8;
    color: rgb(var(--gray-dark));
  }
  .prose p:last-child { margin-bottom: 0; }

  /* ── Stack chips ─────────────────────────────────────── */
  .stack-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .stack-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.35rem 0.8rem;
    border: 1px solid rgb(var(--gray-light));
    border-radius: 8px;
    font-size: 0.82rem;
    font-weight: 500;
    color: rgb(var(--black));
    background: rgba(var(--gray-light), 0.35);
    transition: border-color 140ms, background 140ms;
  }
  .stack-chip:hover {
    border-color: var(--accent);
    background: rgba(var(--gray-light), 0.6);
  }

  /* ── Currently list ──────────────────────────────────── */
  .currently-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .currently-list li {
    display: flex;
    align-items: flex-start;
    gap: 0.7rem;
    font-size: 0.975rem;
    line-height: 1.6;
    color: rgb(var(--gray-dark));
  }

  .dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    flex-shrink: 0;
    margin-top: 0.48rem;
  }
  .dot--green  { background: #22c55e; }
  .dot--blue   { background: var(--accent); }
  .dot--purple { background: #a855f7; }
  .dot--orange { background: #f97316; }

  /* ── Quote ───────────────────────────────────────────── */
  .about-quote {
    margin: 3.5rem 0 0;
    padding: 1.5rem 1.75rem;
    border-left: 3px solid var(--accent);
    border-radius: 0 10px 10px 0;
    background: rgba(var(--gray-light), 0.3);
    font-size: 1rem;
    font-style: italic;
    line-height: 1.7;
    color: rgb(var(--gray-dark));
  }
  .about-quote cite {
    display: block;
    margin-top: 0.6rem;
    font-size: 0.82rem;
    font-style: normal;
    color: rgb(var(--gray));
  }

  /* ── Responsive ──────────────────────────────────────── */
  @media (max-width: 600px) {
    .about-hero {
      flex-direction: column;
      align-items: flex-start;
      gap: 1.25rem;
      margin-top: 2rem;
      padding: 0 1rem 2rem;
    }
    .avatar { width: 72px; height: 72px; font-size: 1.2rem; }
    .hero-name { font-size: 1.6rem; }
    .about-body { padding: 0 1rem 4rem; }
  }
</style>
