---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { Icon } from 'astro-icon/components';
import { getCollection } from 'astro:content';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const allPosts = await getCollection('blog');
const recentPosts = allPosts
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 5);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<!-- ── Hero ──────────────────────────────────────────── -->
			<section class="hero">
				<div class="hero-inner">
					<p class="hero-eyebrow">Personal Blog</p>
					<h1 class="hero-title">Hi, I'm <span class="hero-name">FenMin</span></h1>
					<p class="hero-bio">
						I write about software, design, and things I find interesting.
						This is a place for ideas worth sharing.
					</p>
					<div class="hero-ctas">
						<a href="/blog" class="cta-primary">
							<Icon name="lucide:book-open" width={16} height={16} />
							Browse Blog
						</a>
						<a href="/about" class="cta-secondary">
							<Icon name="lucide:user" width={16} height={16} />
							About Me
						</a>
					</div>
				</div>
				<div class="hero-divider" aria-hidden="true"></div>
			</section>

			<!-- ── Latest Articles ───────────────────────────────── -->
			<section class="latest">
				<div class="latest-inner">
					<header class="section-header">
						<span class="section-icon">
							<Icon name="lucide:sparkles" width={18} height={18} />
						</span>
						<h2 class="section-title">Latest Articles</h2>
					</header>

					{recentPosts.length === 0 ? (
						<p class="empty-state">No posts published yet.</p>
					) : (
						<ol class="article-list">
							{recentPosts.map((post) => (
								<li class="article-card">
									<a href={`/blog/${post.id}/`} class="article-link">
										<span class="article-meta">
											<span class="article-date">
												<Icon name="lucide:calendar" width={12} height={12} />
												<FormattedDate date={post.data.pubDate} />
											</span>
											{post.data.tags && post.data.tags.length > 0 && (
												<span class="article-tags">
													{post.data.tags.map((tag) => (
														<span class="tag-chip">{tag}</span>
													))}
												</span>
											)}
										</span>
										<h3 class="article-title">{post.data.title}</h3>
										{post.data.description && (
											<p class="article-desc">{post.data.description}</p>
										)}
									</a>
								</li>
							))}
						</ol>
					)}

					<a href="/blog" class="view-all">
						View all posts
						<Icon name="lucide:arrow-right" width={14} height={14} />
					</a>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	/* Override global main constraints for full-width landing page */
	main {
		width: 100%;
		max-width: 100%;
		margin: 0;
		padding: 0;
		flex: 1;
	}

	/* ── Hero ──────────────────────────────────────────────────── */
	.hero {
		width: 100%;
		padding: 5rem 1rem 0;
	}

	.hero-inner {
		max-width: 680px;
		margin: 0 auto;
	}

	.hero-eyebrow {
		margin: 0 0 0.75rem;
		font-size: 0.8rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--accent);
	}

	.hero-title {
		margin: 0 0 1.1rem;
		font-size: clamp(2.4rem, 6vw, 3.6rem);
		font-weight: 700;
		line-height: 1.1;
		color: rgb(var(--black));
	}

	.hero-name {
		color: var(--accent);
	}

	.hero-bio {
		margin: 0 0 2rem;
		font-size: 1.1rem;
		line-height: 1.75;
		color: rgb(var(--gray-dark));
		max-width: 520px;
	}

	.hero-ctas {
		display: flex;
		gap: 0.75rem;
		flex-wrap: wrap;
	}

	.cta-primary,
	.cta-secondary {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		padding: 0.55rem 1.2rem;
		border-radius: 8px;
		font-size: 0.9rem;
		font-weight: 600;
		text-decoration: none;
		transition: opacity 0.15s, box-shadow 0.15s;
	}

	.cta-primary {
		background: var(--accent);
		color: #fff;
	}
	.cta-primary:hover {
		opacity: 0.88;
		color: #fff;
		box-shadow: 0 4px 14px rgba(var(--gray), 30%);
	}

	.cta-secondary {
		background: rgb(var(--surface));
		color: rgb(var(--black));
		border: 1px solid rgb(var(--gray-light));
	}
	.cta-secondary:hover {
		border-color: var(--accent);
		color: var(--accent);
	}

	.hero-divider {
		max-width: 680px;
		margin: 3.5rem auto 0;
		height: 1px;
		background: linear-gradient(
			to right,
			transparent,
			rgb(var(--gray-light)) 20%,
			rgb(var(--gray-light)) 80%,
			transparent
		);
	}

	/* ── Latest Articles ───────────────────────────────────────── */
	.latest {
		width: 100%;
		padding: 3.5rem 1rem 5rem;
	}

	.latest-inner {
		max-width: 680px;
		margin: 0 auto;
	}

	.section-header {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		margin-bottom: 1.75rem;
	}

	.section-icon {
		display: inline-flex;
		align-items: center;
		color: var(--accent);
	}

	.section-title {
		margin: 0;
		font-size: 1.15rem;
		font-weight: 700;
		color: rgb(var(--black));
	}

	/* ── Article list ──────────────────────────────────────────── */
	.article-list {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 0;
	}

	.article-card {
		border-bottom: 1px solid rgb(var(--gray-light));
	}
	.article-card:first-child {
		border-top: 1px solid rgb(var(--gray-light));
	}

	.article-link {
		display: block;
		padding: 1.2rem 0.5rem;
		text-decoration: none;
		color: inherit;
		border-radius: 4px;
		transition: background-color 140ms ease;
	}
	.article-link:hover {
		background: rgba(var(--gray-light), 0.5);
	}

	.article-meta {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		flex-wrap: wrap;
		margin-bottom: 0.35rem;
	}

	.article-date {
		display: inline-flex;
		align-items: center;
		gap: 0.3rem;
		font-size: 0.78rem;
		color: rgb(var(--gray));
	}

	.article-tags {
		display: inline-flex;
		flex-wrap: wrap;
		gap: 0.3rem;
	}

	.tag-chip {
		display: inline-block;
		padding: 0.15rem 0.55rem;
		border-radius: 99px;
		font-size: 0.7rem;
		font-weight: 500;
		background: rgba(var(--gray-light), 0.8);
		color: rgb(var(--gray-dark));
	}

	.article-title {
		margin: 0 0 0.3rem;
		font-size: 1.05rem;
		font-weight: 600;
		color: rgb(var(--black));
		line-height: 1.35;
		transition: color 140ms ease;
	}
	.article-link:hover .article-title {
		color: var(--accent);
	}

	.article-desc {
		margin: 0;
		font-size: 0.85rem;
		line-height: 1.55;
		color: rgb(var(--gray));
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	/* ── View all ──────────────────────────────────────────────── */
	.view-all {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		margin-top: 1.5rem;
		font-size: 0.875rem;
		font-weight: 600;
		color: var(--accent);
		text-decoration: none;
		transition: gap 0.15s;
	}
	.view-all:hover {
		gap: 0.55rem;
	}

	.empty-state {
		color: rgb(var(--gray));
		font-size: 0.9rem;
	}

	/* ── Responsive ────────────────────────────────────────────── */
	@media (max-width: 640px) {
		.hero {
			padding: 3rem 1rem 0;
		}
		.hero-bio {
			font-size: 1rem;
		}
		.latest {
			padding: 2.5rem 1rem 4rem;
		}
	}
</style>
