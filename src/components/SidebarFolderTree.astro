---
interface SidebarNode {
  type: 'folder' | 'post';
  label: string;
  slug?: string;
  children: SidebarNode[];
}

interface Props {
  nodes: SidebarNode[];
  currentSlug?: string;
  depth?: number;
}

const { nodes, currentSlug, depth = 0 } = Astro.props;
---

<ul class:list={['sf-list', depth === 0 ? 'sf-root' : 'sf-children']}>
  {nodes.map((node) => (
    <li class:list={['sf-item', node.type === 'folder' ? 'sf-folder-item' : 'sf-post-item']}>
      {node.type === 'folder' ? (
        <>
          <span class="sf-folder-label">{node.label}</span>
          {node.children.length > 0 && (
            <Astro.self nodes={node.children} currentSlug={currentSlug} depth={depth + 1} />
          )}
        </>
      ) : (
        <a
          class:list={['sf-post-link', { 'is-active': currentSlug === node.slug }]}
          href={`/blog/${node.slug}/`}
        >
          {node.label}
        </a>
      )}
    </li>
  ))}
</ul>

<style>
  /* Root: no indent, no line */
  .sf-root {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  /* Children: indent + vertical guide line */
  .sf-children {
    list-style: none;
    margin: 0;
    padding: 0 0 0 0.9rem;
    margin-left: 0.5rem;
    border-left: 1.5px solid var(--sidebar-separator);
  }

  .sf-item {
    position: relative;
  }

  /* Horizontal connector from guide to item */
  .sf-children > .sf-item::before {
    content: '';
    position: absolute;
    left: -0.9rem;
    top: 0.82rem;
    width: 0.55rem;
    height: 1.5px;
    background: var(--sidebar-separator);
  }

  /* Folder label */
  .sf-folder-label {
    display: block;
    padding: 0.22rem 0.3rem;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--sidebar-folder);
    user-select: none;
  }

  /* Post link */
  .sf-post-link {
    display: block;
    padding: 0.26rem 0.4rem;
    border-radius: 6px;
    font-size: 0.82rem;
    font-weight: 400;
    text-decoration: none;
    color: var(--sidebar-link);
    line-height: 1.35;
    border-left: 2px solid transparent;
    transition: color 150ms ease, background-color 150ms ease, border-color 150ms ease;
  }

  .sf-post-link:hover {
    color: var(--sidebar-link-hover);
    background: var(--sidebar-active-bg);
  }

  .sf-post-link.is-active {
    background: var(--sidebar-active-bg);
    border-left-color: var(--sidebar-active-border);
    color: var(--sidebar-link-hover);
    font-weight: 600;
  }
</style>
