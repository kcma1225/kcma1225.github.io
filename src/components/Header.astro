---
import { SITE_TITLE } from '../consts';
import { Icon } from 'astro-icon/components';
import HeaderLink from './HeaderLink.astro';
---

<header class="site-header">
	<div class="header-shell">
		<nav class="site-nav">
			<a class="brand" href="/">
				<img src="/logo.webp" alt="FenMin Blog logo" width="28" height="28" loading="eager" decoding="async" />
				<span>{SITE_TITLE}</span>
			</a>

			<div class="right-controls">
				<div class="internal-links" aria-label="Pages">
					<HeaderLink href="/blog">Blog</HeaderLink>
					<HeaderLink href="/tags">Tags</HeaderLink>
					<HeaderLink href="/about">About</HeaderLink>
				</div>

				<div class="nav-actions">
					<div class="theme-dropdown" data-theme-dropdown>
						<button class="theme-toggle" type="button" aria-label="Select theme" aria-haspopup="true" aria-expanded="false">
							<Icon class="theme-toggle__icon theme-toggle__icon--system" name="lucide:monitor" size={16} aria-hidden="true" />
							<Icon class="theme-toggle__icon theme-toggle__icon--light" name="lucide:sun" size={16} aria-hidden="true" />
							<Icon class="theme-toggle__icon theme-toggle__icon--dark" name="lucide:moon" size={16} aria-hidden="true" />
						</button>

						<div class="theme-menu" role="menu" aria-label="Theme selector">
							<button class="theme-option" type="button" role="menuitemradio" data-theme-option="light">
								<Icon class="theme-option__icon" name="lucide:sun" size={16} aria-hidden="true" />
								<span>Light</span>
							</button>
							<button class="theme-option" type="button" role="menuitemradio" data-theme-option="dark">
								<Icon class="theme-option__icon" name="lucide:moon" size={16} aria-hidden="true" />
								<span>Dark</span>
							</button>
							<button class="theme-option" type="button" role="menuitemradio" data-theme-option="system">
								<Icon class="theme-option__icon" name="lucide:monitor" size={16} aria-hidden="true" />
								<span>System</span>
							</button>
						</div>
					</div>
				</div>
			</div>
		</nav>
	</div>
</header>

<script is:inline>
	(() => {
		const storageKey = 'theme';
		const dark = 'dark';
		const light = 'light';
		const system = 'system';

		const getSystemTheme = () => (window.matchMedia('(prefers-color-scheme: dark)').matches ? dark : light);

		const resolveTheme = (setting) => {
			if (setting === dark || setting === light) return setting;
			return getSystemTheme();
		};

		const getStoredSetting = () => {
			const saved = localStorage.getItem(storageKey);
			if (saved === dark || saved === light || saved === system) return saved;
			return system;
		};

		const setTheme = (setting) => {
			const theme = resolveTheme(setting);
			document.documentElement.setAttribute('data-theme', theme);

			const toggle = document.querySelector('.theme-toggle');
			if (toggle instanceof HTMLButtonElement) {
				toggle.dataset.themeSetting = setting;
			}

			document.querySelectorAll('.theme-option').forEach((element) => {
				if (!(element instanceof HTMLButtonElement)) return;
				const active = element.dataset.themeOption === setting;
				element.setAttribute('aria-checked', String(active));
				element.classList.toggle('is-active', active);
			});
		};

		const dropdown = document.querySelector('[data-theme-dropdown]');
		if (!(dropdown instanceof HTMLElement)) return;

		const toggleButton = dropdown.querySelector('.theme-toggle');
		const menu = dropdown.querySelector('.theme-menu');
		if (!(toggleButton instanceof HTMLButtonElement) || !(menu instanceof HTMLElement)) return;

		const openMenu = () => {
			dropdown.classList.add('is-open');
			toggleButton.setAttribute('aria-expanded', 'true');
		};

		const closeMenu = () => {
			dropdown.classList.remove('is-open');
			toggleButton.setAttribute('aria-expanded', 'false');
		};

		setTheme(getStoredSetting());

		toggleButton.addEventListener('click', () => {
			if (dropdown.classList.contains('is-open')) {
				closeMenu();
			} else {
				openMenu();
			}
		});

		document.addEventListener('click', (event) => {
			if (!dropdown.contains(event.target)) {
				closeMenu();
			}
		});

		menu.querySelectorAll('.theme-option').forEach((element) => {
			if (!(element instanceof HTMLButtonElement)) return;
			element.addEventListener('click', () => {
				const setting = element.dataset.themeOption;
				if (setting !== light && setting !== dark && setting !== system) return;
				localStorage.setItem(storageKey, setting);
				setTheme(setting);
				closeMenu();
			});
		});

		window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', () => {
			if (getStoredSetting() === system) {
				setTheme(system);
			}
		});
	})();
</script>

<style>
	.site-header {
		margin: 0;
		background: rgb(var(--surface));
		box-shadow: 0 2px 8px rgba(var(--black), 5%);
	}

	.header-shell {
		width: 100%;
		max-width: 1100px;
		margin: 0 auto;
		padding: 0 1rem;
		box-sizing: border-box;
	}

	.site-nav {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: space-between;
		min-height: 4.5rem;
		gap: 0.75rem;
	}

	.brand {
		display: inline-flex;
		align-items: center;
		gap: 0.55rem;
		min-height: 44px;
		color: rgb(var(--gray-dark));
		text-decoration: none;
		font-weight: 700;
		font-size: calc(1.15rem);
	}

	.brand img {
		width: 28px;
		height: 28px;
		object-fit: contain;
	}

	.right-controls {
		display: flex;
		align-items: center;
		width: auto;
		flex: 1 1 auto;
		min-width: 0;
		margin-left: auto;
		gap: 0.5rem;
		justify-content: space-between;
	}

	.internal-links {
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		gap: 0.1rem;
		justify-content: flex-end;
		min-width: 0;
	}

	.internal-links a {
		min-height: 44px;
		padding: 0.7rem 0.5rem;
		color: rgb(var(--gray-dark));
		border-bottom: 4px solid transparent;
		text-decoration: none;
		display: inline-flex;
		align-items: center;
		font-size: calc(1.05rem);
	}

	.internal-links a.active {
		text-decoration: none;
		border-bottom-color: var(--accent);
	}

	.nav-actions {
		display: flex;
		align-items: center;
		gap: 0.4rem;
		flex-shrink: 0;
	}

	.theme-toggle {
		border: 1px solid rgb(var(--gray-light));
		background: rgb(var(--surface));
		color: rgb(var(--gray-dark));
		border-radius: 8px;
		padding: 0.55rem;
		min-height: 44px;
		min-width: 44px;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		cursor: pointer;
	}

	.theme-toggle:hover {
		border-color: rgb(var(--gray));
	}

	.theme-dropdown {
		position: relative;
	}

	.theme-menu {
		display: none;
		position: absolute;
		top: calc(100% + 0.4rem);
		right: 0;
		min-width: 130px;
		padding: 0.4rem;
		border: 1px solid rgb(var(--gray-light));
		border-radius: 8px;
		background: rgb(var(--surface));
		box-shadow: var(--box-shadow);
		z-index: 30;
	}

	.theme-dropdown.is-open .theme-menu {
		display: grid;
		gap: 0.25rem;
	}

	.theme-option {
		border: 0;
		background: transparent;
		color: rgb(var(--gray-dark));
		text-align: left;
		padding: 0.6rem 0.55rem;
		min-height: 44px;
		border-radius: 6px;
		cursor: pointer;
		display: flex;
		align-items: center;
		gap: 0.45rem;
	}

	.theme-option:hover,
	.theme-option.is-active {
		background: rgb(var(--gray-light));
	}

	.theme-toggle__icon {
		line-height: 1;
		display: inline-flex;
		align-items: center;
	}

	.theme-toggle__icon--light,
	.theme-toggle__icon--dark {
		display: none;
	}

	.theme-toggle[data-theme-setting='light'] .theme-toggle__icon--light {
		display: inline-flex;
	}

	.theme-toggle[data-theme-setting='light'] .theme-toggle__icon--system,
	.theme-toggle[data-theme-setting='light'] .theme-toggle__icon--dark {
		display: none;
	}

	.theme-toggle[data-theme-setting='dark'] .theme-toggle__icon--dark {
		display: inline-flex;
	}

	.theme-toggle[data-theme-setting='dark'] .theme-toggle__icon--system,
	.theme-toggle[data-theme-setting='dark'] .theme-toggle__icon--light {
		display: none;
	}

	.theme-toggle[data-theme-setting='system'] .theme-toggle__icon--system {
		display: inline-flex;
	}

	.theme-toggle[data-theme-setting='system'] .theme-toggle__icon--light,
	.theme-toggle[data-theme-setting='system'] .theme-toggle__icon--dark {
		display: none;
	}

	.theme-option__icon {
		display: inline-flex;
		align-items: center;
	}

	@media (min-width: 641px) {
		.header-shell {
			padding: 0 1.25rem;
		}

		.right-controls {
			width: auto;
			justify-content: flex-end;
		}
	}

	@media (min-width: 1024px) {
		.header-shell {
			padding: 0 1.5rem;
		}

		.internal-links a {
			padding-left: 0.6rem;
			padding-right: 0.6rem;
		}
	}
</style>
