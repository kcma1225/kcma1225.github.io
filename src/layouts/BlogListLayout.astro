---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import SidebarTreeNav from '../components/SidebarTreeNav.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import type { CollectionEntry } from 'astro:content';
import type { TagSummary } from '../utils/tags';
import type { TreeNode } from '../utils/tree';

interface Props {
  // ── Tree / directory mode (used by /blog) ───────────────
  tree?: TreeNode[];
  allPosts?: CollectionEntry<'blog'>[];
  // ── Tag filter mode (used by /tags/[tag]) ───────────────
  posts?: CollectionEntry<'blog'>[];
  allTags?: TagSummary[];
  currentTag?: string;
}

const {
  tree,
  allPosts = [],
  posts = [],
  allTags = [],
  currentTag,
} = Astro.props;

const isDirMode = !!tree;
const totalAll = allPosts.length;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`Blog — ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <div class="blog-layout">

      <!-- ── Left Sidebar ──────────────────────────────── -->
      <aside class="blog-sidebar">
        <nav class="sidebar-nav">

          {/* Tree / dir mode: ALL POSTS + recursive folder tree */}
          {isDirMode && (
            <button class="sidebar-all sidebar-active" data-filter="__all__">
              All Posts
              <span class="sidebar-tag-count">({totalAll})</span>
            </button>
          )}
          {isDirMode && tree && tree.length > 0 && (
            <>
              <div class="sidebar-divider" />
              <div class="sidebar-tree">
                <SidebarTreeNav nodes={tree} />
              </div>
            </>
          )}

          {/* Tag mode: ALL POSTS + tag list */}
          {!isDirMode && (
            <a href="/blog/" class="sidebar-all">
              All Posts
            </a>
          )}
          {!isDirMode && allTags.length > 0 && (
            <ul class="sidebar-tag-list">
              {allTags.map((tag) => (
                <li>
                  <a
                    href={`/tags/${tag.slug}/`}
                    class:list={['sidebar-tag', { 'sidebar-active': currentTag === tag.slug }]}
                  >
                    <span class="sidebar-tag-name">{tag.name.toUpperCase()}</span>
                    <span class="sidebar-tag-count">({tag.count})</span>
                  </a>
                </li>
              ))}
            </ul>
          )}

        </nav>
      </aside>

      <!-- ── Post List ──────────────────────────────────── -->
      <main class="blog-main">

        {/* ── Tree / dir mode: flat list of all posts sorted by date ── */}
        {isDirMode && allPosts.length === 0 && <p class="blog-empty">No posts found.</p>}
        {isDirMode && (
          <ol class="post-list">
            {allPosts.map((post) => (
              <li class="post-card" data-post-path={post.id}>
                <a href={`/blog/${post.id}/`} class="post-card-link">
                  <time class="post-date"><FormattedDate date={post.data.pubDate} /></time>
                  <h2 class="post-title">{post.data.title}</h2>
                  {post.data.tags && post.data.tags.length > 0 && (
                    <div class="post-tags">
                      {post.data.tags.map((tag) => <span class="post-tag">{tag.toUpperCase()}</span>)}
                    </div>
                  )}
                  {post.data.description && <p class="post-desc">{post.data.description}</p>}
                </a>
              </li>
            ))}
          </ol>
        )}

        {/* ── Tag filter mode: flat list ── */}
        {!isDirMode && posts.length === 0 && <p class="blog-empty">No posts found.</p>}

        {!isDirMode && posts.length > 0 && (
          <ol class="post-list">
            {posts.map((post) => (
              <li class="post-card">
                <a href={`/blog/${post.id}/`} class="post-card-link">
                  <time class="post-date"><FormattedDate date={post.data.pubDate} /></time>
                  <h2 class="post-title">{post.data.title}</h2>
                  {post.data.tags && post.data.tags.length > 0 && (
                    <div class="post-tags">
                      {post.data.tags.map((tag) => <span class="post-tag">{tag.toUpperCase()}</span>)}
                    </div>
                  )}
                  {post.data.description && <p class="post-desc">{post.data.description}</p>}
                </a>
              </li>
            ))}
          </ol>
        )}

      </main>
    </div>
    <Footer />

    <script is:inline>
      (function () {
        /* ── Tree toggle (expand / collapse folders) ─────────────── */
        document.querySelectorAll('[data-toggle]').forEach(function (toggleBtn) {
          toggleBtn.addEventListener('click', function (e) {
            e.stopPropagation();
            var folder = toggleBtn.closest('.stree-folder');
            if (!folder) return;
            var wrap = folder.querySelector(':scope > .stree-children');
            if (!wrap) return;
            var isOpen = wrap.classList.contains('is-open');
            wrap.classList.toggle('is-open', !isOpen);
            toggleBtn.setAttribute('aria-expanded', isOpen ? 'false' : 'true');
          });
        });

        /* ── Dir-mode post filter ────────────────────────────────── */
        var allBtn = document.querySelector('button[data-filter="__all__"]');
        if (!allBtn) return; // tag mode — no filter needed

        var cards    = document.querySelectorAll('[data-post-path]');
        var selects  = document.querySelectorAll('.stree-select[data-filter]');

        function matchesFilter(postPath, filterPath) {
          if (filterPath === '__all__') return true;
          // Only direct children: path must start with "filterPath/"
          // and have no further "/" after that prefix.
          if (!postPath.startsWith(filterPath + '/')) return false;
          var remainder = postPath.slice(filterPath.length + 1);
          return remainder.indexOf('/') === -1;
        }

        function setFilter(filterPath) {
          /* Update "All Posts" button */
          allBtn.classList.toggle('sidebar-active', filterPath === '__all__');

          /* Update tree folder active states */
          selects.forEach(function (btn) {
            btn.classList.toggle('is-active', btn.getAttribute('data-filter') === filterPath);
          });

          /* Show / hide post cards */
          cards.forEach(function (card) {
            var p = card.getAttribute('data-post-path') || '';
            card.style.display = matchesFilter(p, filterPath) ? '' : 'none';
          });
        }

        allBtn.addEventListener('click', function () { setFilter('__all__'); });

        selects.forEach(function (btn) {
          btn.addEventListener('click', function () {
            var f = btn.getAttribute('data-filter');
            if (f) setFilter(f);
          });
        });
      })();
    </script>
  </body>
</html>

<style>
  /* ── Page shell ──────────────────────────────────────── */
  body {
    margin: 0;
  }

  .blog-layout {
    position: relative;
    width: 100%;
    max-width: 1100px;
    margin: 0 auto;
    min-height: calc(100dvh - 60px);
  }

  /* ── Left sidebar ─── absolute within layout ──────────── */
  .blog-sidebar {
    position: absolute;
    top: 0;
    left: 0;
    width: 240px;
    height: 100%;
    overflow-y: auto;
    border-right: 1px solid rgb(var(--gray-light));
    background: rgb(var(--surface));
  }

  .sidebar-nav {
    display: flex;
    flex-direction: column;
    padding: 1.5rem 0.75rem 3rem;
    gap: 0.25rem;
  }

  /* ── Sidebar filter buttons (reset native styles) ───── */
  button.sidebar-all,
  button.sidebar-tag {
    appearance: none;
    background: none;
    border: none;
    cursor: pointer;
    font-family: inherit;
    width: 100%;
    text-align: left;
  }

  .sidebar-all {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.55rem 0.75rem;
    margin-bottom: 0.5rem;
    border-radius: 8px;
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-decoration: none;
    text-transform: uppercase;
    color: rgb(var(--black));
    border: 1px solid transparent;
    transition: background 140ms, border-color 140ms;
  }
  .sidebar-all:hover {
    background: rgba(var(--gray-light), 0.7);
  }
  .sidebar-all.sidebar-active {
    color: var(--accent);
    background: rgba(var(--gray-light), 0.5);
    border-color: rgb(var(--gray-light));
  }

  .sidebar-divider {
    height: 1px;
    background: rgb(var(--gray-light));
    margin: 0.25rem 0 0.75rem;
  }

  .sidebar-tag-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .sidebar-tag {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.4rem;
    padding: 0.5rem 0.75rem;
    border-radius: 8px;
    border-left: 3px solid transparent;
    text-decoration: none;
    color: rgb(var(--gray-dark));
    transition: background 140ms, color 140ms, border-color 140ms;
  }
  .sidebar-tag:hover {
    background: rgba(var(--gray-light), 0.7);
    color: rgb(var(--black));
  }
  .sidebar-tag.sidebar-active {
    color: var(--accent);
    font-weight: 700;
    background: rgba(var(--gray-light), 0.5);
    border-left-color: var(--accent);
  }

  .sidebar-tag-name {
    font-size: 0.92rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    flex: 1;
  }

  .sidebar-tag-count {
    font-size: 0.82rem;
    color: rgb(var(--gray));
    flex-shrink: 0;
  }
  .sidebar-tag.sidebar-active .sidebar-tag-count {
    color: var(--accent);
    opacity: 0.75;
  }

  /* ── Sidebar folder tree ─────────────────────────────── */
  .sidebar-tree {
    margin-top: 0.25rem;
  }

  /* ── Main post list ──────────────────────────────────── */
  .blog-main {
    /* offset for fixed sidebar */
    margin-left: 240px;
    min-width: 0;
    /* Override global `main` rules which inject 3em padding and 720px width */
    width: auto !important;
    max-width: none !important;
    margin-right: 0 !important;
    margin-top: 0 !important;
    margin-bottom: 0 !important;
    padding: 1.75rem 2.5rem 5rem !important;
  }

  .blog-empty {
    color: rgb(var(--gray));
    font-size: 0.9rem;
  }

  .post-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
  }

  .post-card {
    border-bottom: 1px solid rgb(var(--gray-light));
  }

  .post-card-link {
    display: block;
    padding: 1.5rem 0.5rem;
    text-decoration: none;
    color: inherit;
    border-radius: 6px;
    transition: background 140ms;
  }
  .post-card-link:hover {
    background: rgba(var(--gray-light), 0.35);
  }

  .post-date {
    display: block;
    font-size: 0.8rem;
    color: rgb(var(--gray));
    margin-bottom: 0.4rem;
  }

  .post-title {
    margin: 0 0 0.55rem;
    font-size: 1.3rem;
    font-weight: 700;
    color: rgb(var(--black));
    line-height: 1.25;
    transition: color 140ms;
  }
  .post-card-link:hover .post-title {
    color: var(--accent);
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-bottom: 0.65rem;
  }

  .post-tag {
    display: inline-block;
    padding: 0.18rem 0.6rem;
    border: 1px solid var(--accent);
    border-radius: 99px;
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: var(--accent);
    background: transparent;
  }

  .post-desc {
    margin: 0;
    font-size: 0.9rem;
    line-height: 1.6;
    color: rgb(var(--gray-dark));
  }

  /* ── Responsive ──────────────────────────────────────── */
  @media (max-width: 860px) {
    .blog-sidebar {
      width: 200px;
    }
    .blog-main {
      margin-left: 200px;
      padding: 1.5rem 1.5rem 4rem !important;
    }
  }

  @media (max-width: 640px) {
    .blog-sidebar {
      position: static;
      width: 100%;
      height: auto;
      border-right: none;
      border-bottom: 1px solid rgb(var(--gray-light));
    }
    .sidebar-nav {
      flex-direction: row;
      flex-wrap: wrap;
      padding: 0.75rem;
      gap: 0.35rem;
    }
    .sidebar-divider { display: none; }
    .sidebar-tag-list {
      flex-direction: row;
      flex-wrap: wrap;
      gap: 0.35rem;
    }
    .sidebar-all {
      margin-bottom: 0;
      font-size: 0.88rem;
    }
    .sidebar-tag {
      border-left: none;
      border-bottom: 2px solid transparent;
      border-radius: 6px;
      padding: 0.35rem 0.6rem;
    }
    .sidebar-tag.sidebar-active {
      border-bottom-color: var(--accent);
    }
    .blog-main {
      margin-left: 0 !important;
      padding: 1.25rem 1rem 4rem !important;
    }
  }
</style>
